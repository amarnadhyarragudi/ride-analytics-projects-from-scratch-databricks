{
  "datasets": [
    {
      "name": "1de01462",
      "displayName": "Live KPIs",
      "queryLines": [
        "select \r\n",
        "total_revenue_inr,\r\n",
        "cancellation_rate_pct,\r\n",
        "active_drivers,\r\n",
        "avg_fare_inr,\r\n",
        "CAST(ROUND(total_rides * (100- cancellation_rate_pct) / 100,0) AS BIGINT) AS completed_rides\r\n",
        "from  workspace.realtime.gold_live_kpis"
      ],
      "catalog": "workspace",
      "schema": "realtime"
    },
    {
      "name": "08cd8c71",
      "displayName": "Revenue per Minute",
      "queryLines": [
        "SELECT \r\n",
        "minute_bucket,\r\n",
        "revenue_inr,\r\n",
        "completed_rides\r\n",
        "from workspace.realtime.gold_revenue_per_minute\r\n",
        "ORDER BY minute_bucket"
      ]
    },
    {
      "name": "55740af0",
      "displayName": "Ride Status Mix",
      "queryLines": [
        "select status, CAST(ride_count AS bigint) AS ride_count\r\n",
        "from workspace.realtime.gold_ride_status_breakdown\r\n",
        "order by ride_count desc"
      ],
      "catalog": "workspace",
      "schema": "realtime"
    },
    {
      "name": "fc562370",
      "displayName": "City Performance",
      "queryLines": [
        "select city, round(revenue_inr, 0) as revenue_inr\r\n",
        "from workspace.realtime.gold_rides_by_city\r\n",
        "order by revenue_inr desc"
      ],
      "catalog": "workspace",
      "schema": "realtime"
    },
    {
      "name": "bca1b3fb",
      "displayName": "Top Revenue Zones",
      "queryLines": [
        "select \r\n",
        "zone_id,city,round(total_revenue_inr,0) as total_revenue,\r\n",
        "cast(completed_rides as bigint) as completed_rides,\r\n",
        "round(avg_fare_inr,0) as avg_fare_inr\r\n",
        "from workspace.realtime.gold_top_zones\r\n",
        "order by total_revenue_inr desc limit 10"
      ]
    },
    {
      "name": "4f98dd80",
      "displayName": "Cancellation Reasons",
      "queryLines": [
        "select city, coalesce(nullif(cancellation_reason,''),status) as reason, sum(cancellation_count) as cancellation_count\r\n",
        "from workspace.realtime.gold_cancellation_analysis\r\n",
        "group by city, coalesce(nullif(cancellation_reason,''),status)\r\n",
        "order by cancellation_count desc"
      ]
    },
    {
      "name": "4181dada",
      "displayName": "Pickup Demond",
      "queryLines": [
        "SELECT\r\n",
        "  city,\r\n",
        "  pickup_area,\r\n",
        "  zone_id,\r\n",
        "  CAST(SUM(total_rides) AS BIGINT) AS total_rides,\r\n",
        "  CAST(SUM(cancelled_rides) AS BIGINT) AS cancelled_rides,\r\n",
        "  ROUND(SUM(cancelled_rides) * 100.0 / NULLIF(SUM(total_rides), 0), 1) AS cancel_rate_pct\r\n",
        "FROM\r\n",
        "  workspace.realtime.gold_pickup_demand\r\n",
        "GROUP BY\r\n",
        "  city,\r\n",
        "  pickup_area,\r\n",
        "  zone_id\r\n",
        "ORDER BY\r\n",
        "  total_rides DESC"
      ]
    }
  ],
